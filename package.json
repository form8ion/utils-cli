{
  "name": "@form8ion/utils-cli",
  "description": "cli for various tools for the organization",
  "license": "MIT",
  "version": "0.0.0-semantically-released",
  "type": "module",
  "engines": {
    "node": "^22.22.2 || >=24.15"
  },
  "author": "Matt Travi <npm@travi.org> (https://matt.travi.org/)",
  "repository": "form8ion/utils-cli",
  "bugs": "https://github.com/form8ion/utils-cli/issues",
  "homepage": "https://www.npmjs.com/package/@form8ion/utils-cli",
  "bin": {
    "form8ion-utils": "./bin/form8ion-utils.js"
  },
  "sideEffects": false,
  "scripts": {
    "test": "npm-run-all --print-label --parallel lint:* --parallel test:*",
    "lint:engines": "ls-engines",
    "lint:gherkin": "gplint --config .gplintrc.json",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "run-s 'lint:js -- --fix'",
    "lint:lockfile": "lockfile-lint",
    "lint:md": "remark . --frail",
    "lint:peer": "npm ls >/dev/null",
    "prelint:publish": "run-s build",
    "lint:publish": "publint --strict",
    "lint:sensitive": "ban",
    "pretest:e2e": "run-s build",
    "test:e2e": "NODE_OPTIONS=--enable-source-maps node ./test/e2e/smoke-test.js",
    "test:unit": "run-s 'test:unit:base -- --coverage'",
    "test:unit:base": "NODE_ENV=test DEBUG=any vitest run src/",
    "test:integration": "run-s 'test:integration:base -- --profile noWip'",
    "test:integration:base": "NODE_OPTIONS=--enable-source-maps DEBUG=${DEBUG:+$DEBUG,}any cucumber-js test/integration",
    "test:integration:debug": "DEBUG=test:* run-s test:integration",
    "test:integration:focus": "run-s 'test:integration:base -- --profile focus'",
    "test:integration:focus:debug": "DEBUG=test:* run-s 'test:integration:focus'",
    "test:integration:wip": "run-s 'test:integration:base -- --profile wip'",
    "prebuild": "run-s clean",
    "build": "npm-run-all --print-label --parallel build:*",
    "build:js": "rollup --config",
    "clean": "rimraf ./bin",
    "prepack": "run-s build",
    "prepare": "husky",
    "watch": "run-s 'build:js -- --watch'"
  },
  "files": [
    "bin/"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "npm@11.18.0+sha512.4faecce0be70366d1c67b1012c4adc1246354a6cc45bf589f92003073b05518d547403df1475c542d67a4845e22b4fafcd7cac0af02c7a96cc6814f09eb003fb",
  "dependencies": {
    "@form8ion/cli-core": "1.1.1",
    "@form8ion/codecov": "8.0.0-beta.5",
    "@form8ion/core": "5.0.0-beta.15",
    "@form8ion/cucumber-scaffolder": "5.9.0",
    "@form8ion/github": "4.0.0-beta.2",
    "@form8ion/github-actions-node-ci": "5.1.0",
    "@form8ion/github-core": "2.0.0",
    "@form8ion/github-workflows": "2.2.0",
    "@form8ion/hapi-scaffolder": "5.0.0-alpha.7",
    "@form8ion/javascript": "16.0.0-beta.14",
    "@form8ion/javascript-core": "13.0.0",
    "@form8ion/jetbrains": "1.1.4",
    "@form8ion/lift": "12.0.0-beta.7",
    "@form8ion/mocha-scaffolder": "6.1.1",
    "@form8ion/octoherd-script": "1.0.0",
    "@form8ion/ossf-scorecard": "1.2.3",
    "@form8ion/prettier": "3.1.0",
    "@form8ion/project": "22.0.0-beta.26",
    "@form8ion/remark-plugin-scaffolder": "4.0.1",
    "@form8ion/remove-greenkeeper": "3.0.1",
    "@form8ion/renovate-scaffolder": "3.0.1",
    "@form8ion/replace-travis-ci-with-github-actions": "10.0.1",
    "@form8ion/results-reporter": "1.1.0",
    "@form8ion/rollup": "6.0.1",
    "@form8ion/scaffolder-scaffolder": "7.0.5",
    "@form8ion/vite": "3.0.1",
    "@form8ion/vitest": "6.6.1",
    "update-notifier": "7.3.1",
    "yargs": "18.0.0"
  },
  "devDependencies": {
    "@codecov/rollup-plugin": "2.0.1",
    "@cucumber/cucumber": "13.0.0",
    "@form8ion/commitlint-config": "2.0.17",
    "@form8ion/eslint-config": "7.0.18",
    "@form8ion/eslint-config-cucumber": "1.4.1",
    "@form8ion/eslint-config-mocha": "3.0.6",
    "@form8ion/eslint-config-vitest": "1.1.0",
    "@form8ion/remark-lint-preset": "6.0.7",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@travi/any": "3.3.0",
    "@vitest/coverage-v8": "4.1.9",
    "ban-sensitive-files": "1.10.11",
    "chai": "6.2.2",
    "clear-module": "4.1.3",
    "cz-conventional-changelog": "3.3.0",
    "debug": "4.4.3",
    "deep-equal": "2.2.3",
    "execa": "9.6.1",
    "gplint": "2.5.2",
    "http-status-codes": "2.3.0",
    "husky": "9.1.7",
    "js-yaml": "5.2.0",
    "lockfile-lint": "5.0.0",
    "ls-engines": "0.10.1",
    "mdast-util-from-markdown": "2.0.3",
    "mdast-zone": "6.1.0",
    "mock-fs": "5.5.0",
    "msw": "2.14.6",
    "npm-run-all2": "9.0.2",
    "publint": "0.3.21",
    "remark-cli": "12.0.1",
    "rimraf": "6.1.3",
    "rollup": "4.62.2",
    "rollup-plugin-auto-external": "2.0.0",
    "rollup-plugin-executable": "1.6.3",
    "testdouble": "3.20.2",
    "unist-util-find": "3.0.0",
    "vitest": "4.1.9",
    "vitest-when": "0.10.0"
  }
}
